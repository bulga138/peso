{
  "$schema": "./peso.schema.json",
  "mode": "on",
  "shortPromptThreshold": 15,
  "toolPriorities": {
    "mode": "manual",
    "prefer": ["read", "glob", "grep", "serena_find_symbol", "serena_search_for_pattern"],
    "avoid": ["task", "webfetch", "websearch"],
    "notes": {
      "read": "Low cost — file read, no LLM tokens",
      "glob": "Low cost — pattern match, no LLM tokens",
      "grep": "Low cost — regex search, no LLM tokens",
      "task": "High cost — spawns subagent with full LLM session",
      "webfetch": "Medium cost — network call, content may be large",
      "websearch": "Medium cost — external API call"
    }
  },
  "techniques": {
    "enabled": "all",
    "disabled": []
  },
  "context": {
    "injectGitBranch": true,
    "injectGitChangedFiles": false,
    "injectGitLastCommit": false,
    "injectMcpTools": true,
    "injectProjectInstructions": true,
    "maxChangedFiles": 10
  },
  "options": {
    "baseURL": "{env:ANTHROPIC_BASE_URL}",
    "apiKey": "{env:ANTHROPIC_AUTH_TOKEN}"
  }
}
